{
  // REQUIRED: StreamingVEX server URL (no trailing slash).
  "base_url": "https://your-streamingvex-server.example.com",

  // REQUIRED: supplier_slug — your VEX publisher id on StreamingVEX (register at /ui/supplier).
  //   This is who pushes the document, NOT the upstream product/software vendor. It is not read from
  //   product_cpe or product_purl. Use those fields (or VEX product_tree metadata) for the product vendor.
  //   Example: slug "matchpoint-vex4edk2" (third-party VEX publisher) + CPE vendor "tianocore" (EDK II).
  "supplier_slug": "my-supplier",

  // REQUIRED: Supplier API key (svx_…) — copy when issued; shown only once.
  "api_key": "svx_REPLACE_WITH_KEY_FROM_STREAMINGVEX"

  // OPTIONAL — product identity for catalog indexing (omit when your --file VEX already
  // includes metadata, e.g. CSAF product_tree or OpenVEX product fields). Values here
  // override whatever is in the VEX file. Required only for encrypted VEX (ciphertext
  // cannot be parsed server-side). For a single config pushing many releases, leave these
  // out and let each file supply product_name / product_version.
  // "product_name": "My Product",
  // "product_version": "1.0.0",

  // OPTIONAL — uncomment any lines you need (add a comma after api_key line above first).
  // "product_purl": "pkg:generic/my-product@1.0.0",
  // "product_cpe": "cpe:2.3:a:vendor:product:1.0.0:*:*:*:*:*:*:*",
  // "software_vendor_name": "My Vendor",
  // "signing_key_pem": "./supplier-ed25519-private.pem",
  //
  // Encrypted push from cleartext (--encrypt on streamingvex-push):
  // "encryption_key_file": "./vex-aes256.key",
  // "encryption_key_id": "release-202411",
  //
  // content_encoding — how vex_document is sent in the push envelope (default: "json"):
  //   "json"       Plain OpenVEX, CSAF, or CycloneDX in --file; StreamingVEX parses the document for catalog indexing.
  //   "encrypted"  --file is a ciphertext wrapper (streamingvex_encrypted_vex, key_id, ciphertext, …);
  //                StreamingVEX stores and forwards ciphertext only — subscribers decrypt locally using keys you
  //                distribute out-of-band. product_name/product_version on this config are still required.
  //                Auto-detected when the wrapper marker is present; set explicitly for clarity.
  // "content_encoding": "json"
}
